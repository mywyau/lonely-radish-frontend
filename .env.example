SITE_URL=http://localhost:3000

# Auth0 Regular Web Application credentials (server-side only)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Use an independent random value of at least 32 characters in production.
# The app temporarily falls back to AUTH0_CLIENT_SECRET when this is omitted.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: for a separately registered Auth0 API.
AUTH0_AUDIENCE=

# Auth0 Management API machine-to-machine application. Grant delete:users.
AUTH0_MGMT_CLIENT_ID=your-management-client-id
AUTH0_MGMT_CLIENT_SECRET=your-management-client-secret
AUTH0_MGMT_AUDIENCE=https://your-tenant.eu.auth0.com/api/v2/

# Upstash QStash runs account deletion outside the request lifecycle.
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# PostgreSQL connection used only by the Nuxt server. For serverless production,
# use your provider's transaction-pooler URL and require TLS.
DATABASE_URL=postgresql://user:password@host:6543/database?sslmode=require

# Supabase Storage. The service-role key is server-side only; never expose it
# with a NUXT_PUBLIC_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-server-only-key
NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-side postcode geocoding. Never expose this with a NUXT_PUBLIC_ prefix.
OPENCAGE_API_KEY=your-opencage-key

# Transactional email. Keep the API key server-side.
RESEND_API_KEY=re_your-api-key
EMAIL_FROM=Lonely Radish <notifications@updates.lonelyradish.app>
EMAIL_REPLY_TO=contact@lonelyradish.app
APP_BASE_URL=http://localhost:3000
